{
  "expo": {
    "name": "Canteen App",
    "slug": "canteen-app",
    "scheme": "canteen",
    "icon": "./src/assets/images/canteen_logo_final.png",
    "platforms": [
      "android"
    ],
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Canteen App to use your microphone for voice search.",
          "speechRecognitionPermission": "Allow Canteen App to use speech recognition for voice search."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "networkInspector": false
    },
    "android": {
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.canteen.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/canteen_logo_final.png",
        "backgroundColor": "#ffffff"
      },
      "usesCleartextTraffic": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7c7b15fb-ec6d-45ff-b4ac-df88828a2214"
      }
    },
    "owner": "saugatanath"
  }
}
